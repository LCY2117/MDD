# ─────────────────────────────────────────────────────────────────────────────
# 心语社区 后端环境变量配置
# 使用方式：复制本文件为 .env 并填写对应值
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── 服务器 ────────────────────────────────────────────────────────────────────

# 监听端口（默认 3001）
PORT=3001

# 运行环境：development | production
NODE_ENV=development

# ── 安全 ──────────────────────────────────────────────────────────────────────

# JWT 签名密钥（必填，务必使用足够长的随机字符串）
# 生成示例：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_strong_random_secret

# JWT 过期时间（默认 7d）
# JWT_EXPIRES_IN=7d

# ── 跨域 ──────────────────────────────────────────────────────────────────────

# 允许跨域的前端地址（开发环境默认 http://localhost:5173）
FRONTEND_URL=http://localhost:5173

# ── AI 接口（硅基流动 SiliconFlow）────────────────────────────────────────────

# API Key（必填，AI 对话功能依赖此项）
# 申请地址：https://siliconflow.cn
SILICONFLOW_API_KEY=

# API 基础地址（默认使用官方地址，一般无需修改）
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# 使用的模型（默认 Qwen2.5-72B-Instruct，可替换为其他兼容模型）
AI_MODEL=Qwen/Qwen2.5-72B-Instruct
